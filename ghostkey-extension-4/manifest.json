{
  "manifest_version": 3,
  "name": "LowK",
  "version": "1.0.0",
  "description": "Behavioral biometric guard — detects impostors by how you type on login pages.",
  "permissions": ["storage", "notifications", "windows"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LowK"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
